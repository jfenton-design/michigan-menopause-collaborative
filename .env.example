# Email delivery for RSVP + case submissions (optional)
# When unset, submissions are still saved to data/rsvp.jsonl and data/case.jsonl.
# Sign up at https://resend.com — free tier covers a small org easily.
RESEND_API_KEY=

# From address Resend will send as. Must be on a verified domain in Resend.
RESEND_FROM=notifications@michiganmenopause.com

# Where to deliver RSVP/case notifications. Defaults to hello@michiganmenopause.com.
NOTIFY_EMAIL=hello@michiganmenopause.com
